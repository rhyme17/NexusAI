# NexusAI Backend Configuration
# Copy to .env and customize as needed

# 共识策略 (Consensus Strategy)
# Options: highest_confidence, majority_vote
# Default: highest_confidence
NEXUSAI_CONSENSUS_STRATEGY_DEFAULT=highest_confidence

# 事件历史保留条数 (Event History Retention)
# 单位：条/任务
# 最小值：100，默认值：2000
NEXUSAI_EVENT_HISTORY_MAX=2000

# 最大重试次数 (Max Retries)
# 单位：次
# 默认值：2（可被 task metadata max_retries 覆盖）
NEXUSAI_MAX_RETRIES_DEFAULT=2

# Task Router 策略权重（Week 2）
# 路由总分 = skill_score * SKILL_WEIGHT + status_rank * (STATUS_WEIGHT + priority_bonus) - active_task_count * LOAD_PENALTY
# 默认：skill=100, status=10, load_penalty=1
# NEXUSAI_ROUTER_SKILL_WEIGHT=100
# NEXUSAI_ROUTER_STATUS_WEIGHT=10
# NEXUSAI_ROUTER_LOAD_PENALTY=1
# 优先级附加状态权重（low/medium/high）
# NEXUSAI_ROUTER_PRIORITY_STATUS_BONUS_LOW=0
# NEXUSAI_ROUTER_PRIORITY_STATUS_BONUS_MEDIUM=2
# NEXUSAI_ROUTER_PRIORITY_STATUS_BONUS_HIGH=6

# JSON 过渡持久化 (JSON Transitional Persistence)
# 是否启用 JSON 快照持久化：true/false（默认：true）
NEXUSAI_JSON_PERSISTENCE_ENABLED=true

# JSON 数据目录（默认：backend/data）
# NEXUSAI_DATA_DIR=./data

# 启动时种子数据 (Seed Data)
# 是否启用种子加载：true/false（默认：false）
# NEXUSAI_SEED_ENABLED=false

# 仅在存储为空时应用种子：true/false（默认：true）
# NEXUSAI_SEED_APPLY_IF_EMPTY=true

# 种子文件路径（默认：backend/data/seed.example.json）
# NEXUSAI_SEED_FILE=./data/seed.example.json

# Debug 存储 API（仅本地演示建议开启）
# 是否开放 /api/debug/storage/* 端点：true/false（默认：false）
# NEXUSAI_DEBUG_API_ENABLED=false

# Phase A API Key 鉴权（可选）
# 启用后，/api/* 默认需要 X-API-Key
# NEXUSAI_API_AUTH_ENABLED=false
# NEXUSAI_API_KEYS=dev-key-1,dev-key-2
# 可选：为 key 绑定角色（格式 key:role，逗号分隔；role: admin|operator|viewer）
# NEXUSAI_API_KEY_ROLES=dev-key-1:admin,dev-key-2:viewer
# 未显式绑定时使用默认角色
# NEXUSAI_API_AUTH_DEFAULT_ROLE=viewer
# 可选：覆盖免鉴权路径（逗号分隔）
# NEXUSAI_API_AUTH_EXEMPT_PATHS=/,/health,/docs,/openapi.json,/redoc,/ws

# 启动时引导管理员账号（强烈建议在非本地环境显式覆盖）
# NEXUSAI_AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
# NEXUSAI_AUTH_BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password

# 存储后端 (Storage Backend)
# Options: json, sqlite, postgres
# NEXUSAI_STORAGE_BACKEND=json
# PostgreSQL DSN (when backend=postgres)
# NEXUSAI_POSTGRES_DSN=postgresql://user:password@localhost:5432/nexusai
# PostgreSQL 初始化失败时是否降级（默认 true）
# NEXUSAI_STORAGE_FALLBACK_ON_ERROR=true
# 降级目标（仅支持 json 或 sqlite）
# NEXUSAI_STORAGE_FALLBACK_BACKEND=json

# 维护只读模式（用于停机迁移窗口）
# 启用后，/api/* 的写入请求会返回只读错误
# NEXUSAI_READ_ONLY_MODE=false

# Step 6：内部发布推荐基线（示例，需按环境覆盖）
# 注意：为保证仓库开箱即跑，上述默认注释仍保持本地/演示友好配置；
# 真正完成 Step 5 PostgreSQL cutover 后，建议在部署环境中显式设置：
# NEXUSAI_STORAGE_BACKEND=postgres
# NEXUSAI_POSTGRES_DSN=postgresql://user:password@db-host:5432/nexusai
# NEXUSAI_STORAGE_FALLBACK_ON_ERROR=false
# NEXUSAI_API_AUTH_ENABLED=true
# NEXUSAI_API_KEYS=admin-key,operator-key,viewer-key
# NEXUSAI_API_KEY_ROLES=admin-key:admin,operator-key:operator,viewer-key:viewer
# NEXUSAI_API_AUTH_DEFAULT_ROLE=viewer
# NEXUSAI_DEBUG_API_ENABLED=false
# NEXUSAI_SEED_ENABLED=false
# NEXUSAI_READ_ONLY_MODE=false

# 启动自动清理（可选）
# NEXUSAI_CLEAR_ON_STARTUP=false
# NEXUSAI_CLEAR_EVENTS_ONLY_ON_STARTUP=false
# NEXUSAI_CLEAR_RESTORE_SEED_ON_STARTUP=false

# 真实 Agent 执行入口 (OpenAI-Compatible Provider)
# 兼容 ModelScope OpenAI API
NEXUSAI_AGENT_EXECUTION_BASE_URL=https://api-inference.modelscope.cn/v1
NEXUSAI_AGENT_EXECUTION_MODEL=deepseek-ai/DeepSeek-V3.2

# 推荐配置：二选一
# NEXUSAI_AGENT_EXECUTION_API_KEY=your_token
# MODELSCOPE_TOKEN=your_token

# 推理超时（秒）
# NEXUSAI_AGENT_EXECUTION_TIMEOUT_SECONDS=45

# 执行失败时降级策略：simulate 或 fail（默认 simulate）
# NEXUSAI_AGENT_EXECUTION_FALLBACK=simulate

# FastAPI 服务器配置 (Server Configuration)
# 默认：localhost:8000
# NEXUSAI_HOST=0.0.0.0
# NEXUSAI_PORT=8000

# 日志级别 (Log Level)
# Options: debug, info, warning, error, critical
# LOG_LEVEL=info

# 环境 (Environment)
# Options: development, testing, production
# ENVIRONMENT=development

